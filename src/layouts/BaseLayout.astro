---
/**
 * BaseLayout.astro - Shared layout used by every page in the site.
 *
 * WHAT IS A LAYOUT?
 * In Astro, a layout is just a reusable .astro component that wraps page
 * content. Instead of copying <html>, <head>, and <body> into every page,
 * we define them once here and use a <slot /> to inject each page's unique
 * content. Think of it like a picture frame - the frame stays the same,
 * but the picture inside changes.
 *
 * HOW PROPS WORK:
 * The "Props" interface below defines what data a parent page must pass
 * to this layout. Right now we only require a "title" string, which gets
 * inserted into the <title> tag so each page has its own browser tab name.
 */

// TypeScript interface - tells Astro (and your editor) which props are expected.
interface Props {
    title: string;
}

// Destructure props passed from the parent page
const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<h1>{title}</h1>
	</body>
</html>